# Copy this file to .env.local and fill in real values.
# Vercel-managed env vars don't need to live here for production —
# set them via the Vercel dashboard, vercel env, or auto-provisioned via Marketplace.

# ── AI ──────────────────────────────────────────────────────────────────────
# Required for any Anthropic SDK or AI SDK Anthropic provider use.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional: AI Gateway for routing/failover across providers.
# AI_GATEWAY_API_KEY=

# ── Database (Neon Postgres via Vercel Marketplace) ─────────────────────────
# Auto-provisioned when you add Neon via the Marketplace.
# DATABASE_URL=

# ── Auth (Clerk via Vercel Marketplace) ─────────────────────────────────────
# Auto-provisioned when you add Clerk via the Marketplace.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# ── KV / cache (Upstash Redis via Vercel Marketplace) ───────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Blob (Vercel Blob) ──────────────────────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=

# ── App config ──────────────────────────────────────────────────────────────
# Set the canonical URL for the deployment (used for OG, sitemap, absolute links).
# NEXT_PUBLIC_APP_URL=http://localhost:3000
